#!/bin/sh
# Convenience wrapper around run-mc6809-tests.
#
# The harness itself requires three tools to be reachable via the
# environment:
#   USIM09BATCH   — MC6809 batch simulator (from the usim repo)
#   LLVM_OBJCOPY  — llvm-objcopy built for MC6809
#   LLVM_NM       — llvm-nm built for MC6809
#
# The defaults below assume the other MC6809 repos are siblings of this
# picolibc checkout (see scripts/README-mc6809.md):
#   <repo>/../usim         — github.com/sim6809/usim checkout
#   <repo>/../llvm-mc6809  — llvm-mc6809 checkout with a
#                            cmake-build-debug-system build dir
#
# Already-set environment values are preserved, so override any
# individual path by exporting it before invoking this wrapper.
PARENT=$(cd "$(dirname "$0")/.." && pwd)
PARENT=$(dirname "$PARENT")
LLVM_BUILD_SUBDIR=${LLVM_BUILD_SUBDIR:-llvm/cmake-build-debug-system}
LLVM_BIN=${LLVM_BIN:-${PARENT}/llvm-mc6809/${LLVM_BUILD_SUBDIR}/bin}
: "${USIM09BATCH:=${PARENT}/usim/usim09batch}"
: "${LLVM_OBJCOPY:=${LLVM_BIN}/llvm-objcopy}"
: "${LLVM_NM:=${LLVM_BIN}/llvm-nm}"
export USIM09BATCH LLVM_OBJCOPY LLVM_NM

# Suppress llvm-symbolizer on pre-existing crashes (FP/address-space
# test compilation failures). Each crash spawns llvm-symbolizer which
# walks all loaded dylibs on macOS — tens of seconds per crash.
export LLVM_DISABLE_CRASH_REPORT=1
export LLVM_DISABLE_SYMBOLIZATION=1

exec "$(dirname "$0")/run-mc6809-tests" "$@"
