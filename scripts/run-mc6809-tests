#!/usr/bin/env python3
"""
Run picolibc test binaries via meson, honouring meson's exit-code
semantics (rc=77 SKIP, rc=99 ERROR, should_fail inversion, etc).

Replaces an earlier hand-rolled bash tally that misclassified rc=77
as FAIL and ignored should_fail. Classification is delegated to
`meson test` itself — the source of truth — and we only filter out
tests whose binaries don't currently build, so compile gaps don't
take out the whole run.

Outputs:
  /tmp/picolibc-results.txt   — one line per test, plus tally
  /tmp/picolibc-failures.log  — stdout+stderr of every non-OK test

Preflight: the harness batches `ninja` over every candidate test
binary before running any test, so each ELF matches the current
source. Without this, a source fix that wasn't followed by a rebuild
could be recorded as FAIL against the new git SHA — polluting the
bench ledger. Disable with --no-preflight. NOTE: ninja only tracks
source files, not the compiler binary; a fresh `llc`/`clang` with
unchanged picolibc .c still leaves stale .c.o on disk. Delete .c.o
separately when iterating on backend code (see bench-session skill).

With --record, also writes each run to
  ~/Documents/mc6809-bench/results.sqlite
so cycle counts can be tracked over time. Requires USIM_CYCLES=1
(set automatically) so usim09batch emits cycles=<N> on stderr.

Environment overrides:
  PICOLIBC_BUILDDIR   build directory (default: <repo>/builddir-mc6809)
  USIM09BATCH         USim binary
  LLVM_OBJCOPY        llvm-objcopy
  LLVM_NM             llvm-nm
  MC6809_BENCH_DB     override SQLite path (default: ~/Documents/
                      mc6809-bench/results.sqlite)
"""

import argparse
import json
import os
import re
import sqlite3
import subprocess
import sys
import threading
from collections import Counter
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime, timezone
from pathlib import Path

REPO     = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
BUILDDIR = os.environ.get("PICOLIBC_BUILDDIR", f"{REPO}/builddir-mc6809")

# Suppress llvm-symbolizer + Apple crash reporter noise from clang FP
# aborts (e.g. G_FCMP not legalised) during the preflight ninja step.
# bench-parallel.sh sets these too, but this script is often invoked
# standalone (single-level quick check per bench-session skill).
os.environ.setdefault("LLVM_DISABLE_CRASH_REPORT", "1")
os.environ.setdefault("LLVM_SYMBOLIZER_PATH", "/dev/null")

OUT     = "/tmp/picolibc-results.txt"
FAILLOG = "/tmp/picolibc-failures.log"
LOGBASE = "mc6809-tally"

DEFAULT_DB = Path.home() / "Documents" / "mc6809-bench" / "results.sqlite"

CYCLES_RE = re.compile(r"^cycles=(\d+)\s*$", re.MULTILINE)

# usim09batch exits 124 (GNU `timeout(1)` convention) when --timeout=N
# is hit. meson only sees a non-zero rc and reports FAIL; reclassify
# here so cap-hits appear as TIMEOUT in the ledger instead of polluting
# the FAIL bucket. Bumping USIM_TIMEOUT is the other half of bug #131.
USIM_CAP_RC = 124

# Per-test usim instruction caps. Keys are the bare test name as stored
# in meson's intro-tests.json (what the harness passes to `meson test`);
# meson itself renders a fuller "suite - project:name" form in its logs,
# but that form is derived only after the fact. Measured values from
# run_id=7/9 with ~2x headroom. A single global USIM_TIMEOUT is wrong:
# tight on the slow-but-correct outliers (they trip the cap and get
# misclassified as TIMEOUT) yet far too generous for the fast majority
# (a genuine hang in any fast test sleeps for the slow-test budget).
# This table lets each known-slow test set its own ceiling while
# everything else keeps the tight default. Source of truth is
# reference_slow_test_budgets.md.
SLOW_CAPS = {
    "strcmp-1":     5_000_000_000,
    "test-memset": 18_000_000_000,
    "test-memchr": 25_000_000_000,
    "test-memmem": 80_000_000_000,
}

# Tests that are genuinely too slow for routine tallies (>10 min wall).
# Skipped by default; included only with --slow. Keeps the default
# tally fast without losing the ability to run them when needed.
SLOW_TESTS = {
    "test-memmem",
}

# Bug #204: under MAME (HD6309), these additional tests are genuinely
# too slow for routine tallies — MAME's `-nothrottle` runs ~10x the
# emulated CPU's real speed, which is ~15-18x slower than USim. Tests
# that finish in seconds-to-minutes wall under USim run for tens of
# minutes (and in test-memchr's case, ~27 minutes for all 4 inner
# loop iterations) under MAME. Skipping them under MAME keeps the
# bench tally tractable (~5 min total) without losing coverage —
# they continue to run under USim where the budget IS practical.
#
# Background: PICOLIBC_MAME_TIMEOUT=1800 (the canonical default; see
# feedback_mame_timeout_1800.md) gives MAME 1800 simulated seconds.
# At nothrottle that's ~180-225 s wall — enough for memcpy-1/memmove1
# to pass, but NOT enough for the tests below. Empirically verified
# 2026-05-02: even at PICOLIBC_MAME_TIMEOUT=4000 (sim-sec), test-memchr
# was still in iteration 0 of 4. Increasing the cap into the practical-
# wall-time range would multi-hour every bench, so skip is the right
# move.
#
# Skipped under --simulator=mame only; --slow opts back in if you
# really want to wait.
MAME_SLOW_TESTS = {
    "test-iconv",
    "test-memchr",
    "test-memset",
    "test-timegm",
    "strcmp-1",
    # Bug #266: at -Og hd6309 mame, test-ffs runs ~2.5G HD6309 cycles
    # to completion (100k random-iteration outer loop × 3 ffs/ffsl/ffsll
    # check pairs). Under USim it passes at every level in 13–25 wall-sec
    # (runs 1058–1095). Under MAME the same cycle count exceeds the
    # 1800 sim-sec / ~225 wall-sec budget, exactly like the other entries
    # in this list. Skip-under-MAME, run-under-USim is the same disposition
    # as test-iconv/test-memchr/etc.
    "test-ffs",
}

# Tests that need a real-FS semihost (open/read/write/lseek/stat against
# the host filesystem). USim's semihost is the picolibc "fake" stub set
# — it returns -1 for everything — so these tests universally FAIL at
# every opt level regardless of codegen. Skipping them by default keeps
# the bench ledger honest about codegen quality (otherwise the same 13
# environmental FAILs swamp every report at every level). Include with
# --include-fake-fs when measuring the semihost layer itself, or once
# USim grows real file I/O.
FAKE_FS_TESTS = {
    "test-stat",
    "test-fread-fwrite",
    "test-freopen",
    "test-fopen",
    "test-fgetc",
    "test-fgets-eof",
    "test-mktemp",
    "test-setvbuf",
    "test-wchar",
    "test-ungetc-ftell",
    "test-dprintf",
    "test-posix-io",
    "tzset",
    # test-getdate calls `fopen("test-getdate.txt", "w")` to write the
    # DATEMSK file the test reads back via getdate(). Our semihost has
    # no real filesystem, so fopen-for-write fails immediately and the
    # test errors out (`test-getdate.txt: No such file or directory`).
    # Invisible at non-LTO levels because .text is ~87 KB and overflows
    # the 64-KB address space — link silently fails, no binary built.
    # LTO whole-program DCE compresses it small enough to link, so the
    # test starts running and surfaces the same fake-FS limitation.
    "test-getdate",
}

# Default usim cap for tests not in SLOW_CAPS. Matches run-mc6809's
# own fallback so behaviour is identical between single-test and
# tally invocations. Override via USIM_TIMEOUT env if callers really
# need a different baseline for all tests.
DEFAULT_USIM_TIMEOUT = 2_000_000_000


def _compiler_binaries(builddir):
    """Return the absolute paths of the C/C++ compiler executables this
    builddir was configured with, derived from meson's intro-compilers
    JSON. Skips compiler driver flags (anything starting with `-`).

    Best-effort: returns an empty set if the file is missing or
    malformed, so the staleness check degrades to a no-op rather than
    aborting the tally."""
    try:
        with open(f"{builddir}/meson-info/intro-compilers.json") as f:
            doc = json.load(f)
    except (OSError, json.JSONDecodeError):
        return set()
    paths = set()
    for lang_map in doc.values():
        for lang in lang_map.values():
            for tok in lang.get("exelist", []):
                if tok and not tok.startswith("-") and os.path.isabs(tok):
                    paths.add(tok)
                    break  # first abs path is the executable
    # Also include sibling `llc` if clang lives in an LLVM bin dir;
    # picolibc itself doesn't invoke llc, but a backend rebuild updates
    # both binaries as a unit, so `llc` is a fine proxy for "did the
    # backend change" too.
    for p in list(paths):
        sib = Path(p).with_name("llc")
        if sib.exists():
            paths.add(str(sib))
    return paths


def _archive_path(builddir):
    """Return Path to libc.a in the builddir, or None if absent."""
    p = Path(builddir) / "libc.a"
    return p if p.exists() else None


def _wipe_stale_objects(builddir, verbose=True):
    """Delete every `.c.o` under the builddir. Idempotent.

    Called before ninja when a backend rebuild has been detected — ninja
    can't see compiler-binary mtimes (see `feedback_ninja_compiler_dep.md`),
    so without this wipe the stale objects would be linked into a
    fresh-looking ELF and the recorded result would not match the current
    backend."""
    n = 0
    for root, _, files in os.walk(builddir):
        for name in files:
            if name.endswith(".c.o"):
                try:
                    os.unlink(os.path.join(root, name))
                    n += 1
                except OSError:
                    pass
    if verbose and n:
        print(f"preflight: wiped {n} stale .c.o (backend changed since libc.a)",
              flush=True)
    return n


def preflight_fresh_binaries(skip_ninja=False, verbose=True, builddir=None):
    """Read intro-tests.json, refresh every test binary, return the
    subset that now exists, is executable, AND is no older than the
    backend / libc.a inputs that would invalidate it.

    Without the refresh, `meson test --no-rebuild` runs whatever ELF
    happens to be on disk — even if its source has been edited since
    the last link. Run_ids 13/14/15 recorded `snprintf` = FAIL against
    picolibc `4092ca7a1` (which includes the gate fix `18d9bb4d2`)
    because the on-disk `snprintf.elf` predated that commit; a later
    rebuild produced an ELF that passes. The preflight prevents that
    class of phantom regression. Bug #141.

    Three layers of staleness defence:

    1. **Backend-rebuild detection.** Before ninja, compare the mtime
       of every compiler binary (from meson's intro-compilers.json) to
       libc.a. If any compiler is newer, wipe every `.c.o` in the
       builddir so ninja rebuilds them all. Plugs the gap that ninja
       doesn't track compiler-binary mtimes — the manual `.c.o`-delete
       step the bench-session skill mandates is now automatic.

    2. **Source-change refresh.** All test binaries go through
       `ninja -k 0` in one batch; ninja's `.ninja_deps` tracking
       handles `.c` mtime staleness, and `-k 0` keeps the batch going
       past permanently-broken FP-gated targets (see
       `project_fp_not_enabled.md`).

    3. **Per-ELF freshness audit.** After ninja, each ELF's mtime is
       checked against libc.a and the compiler binaries. Any ELF still
       older than its inputs is dropped from the candidate set with a
       loud warning rather than silently recorded as a result.

    `skip_ninja=True` (`--no-preflight`) disables ALL three layers
    (for callers that know their binaries are fresh, e.g. immediately
    after a manual `cmake --build`). Still runs the existence check
    and drops tests whose link failed.

    `builddir` overrides the module-level `BUILDDIR` for multi-builddir
    callers; legacy single-builddir callers leave it None."""
    bd = builddir or BUILDDIR
    tag = f" [{os.path.basename(bd)}]" if builddir else ""
    with open(f"{bd}/meson-info/intro-tests.json") as f:
        tests = json.load(f)
    cands = [t for t in tests
             if "picolibc:headers" not in t["suite"] and t["cmd"]]
    if not skip_ninja:
        compilers = _compiler_binaries(bd)
        archive = _archive_path(bd)
        if archive and compilers:
            arch_mtime = archive.stat().st_mtime
            newer = [c for c in compilers
                     if os.path.exists(c)
                     and os.stat(c).st_mtime > arch_mtime]
            if newer:
                if verbose:
                    names = ", ".join(os.path.basename(c) for c in newer)
                    print(f"preflight{tag}: backend rebuilt since libc.a "
                          f"({names}); wiping stale objects",
                          flush=True)
                _wipe_stale_objects(bd, verbose=verbose)
        targets = [os.path.relpath(t["cmd"][0], bd) for t in cands]
        if verbose:
            print(f"preflight{tag}: ninja-refresh {len(targets)} test binaries…",
                  flush=True)
        try:
            subprocess.run(
                ["ninja", "-C", bd, "-k", "0"] + targets,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                check=False,
            )
        except FileNotFoundError:
            if verbose:
                print("preflight: ninja not found on PATH; "
                      "skipping refresh (recorded tally may use stale ELFs)",
                      flush=True)
    # Tests whose link failed (e.g. text overflows the 16 KB flash
    # region of the regular linker script) are absent from disk.
    # Bug #237: split them into a separate `buildfail` list so the
    # caller can record them as `BUILDFAIL` in the ledger instead
    # of silently dropping them — a clean tally that hid 27 such
    # build-excludes was exactly the trap that hid bug #224 for
    # weeks.
    keep = []
    buildfail = []
    for t in cands:
        elf = t["cmd"][0]
        if os.path.isfile(elf) and os.access(elf, os.X_OK):
            keep.append(t)
        else:
            buildfail.append(t)
    if not skip_ninja:
        # Bug #280: per-ELF mtime audit was over-aggressive. It compared
        # each ELF against libc.a + compilers and dropped any ELF older
        # than either. At verifier-heavy levels (Og variants under Bug
        # #269's -mllvm -verify-machineinstrs gate), a partial libc.a
        # rebuild (some .c.o's fail to compile due to verifier hits, the
        # rest succeed) updates libc.a's mtime even though the test
        # binaries' actual link inputs (the surviving .o's) haven't
        # changed in a way that requires re-linking. ninja's per-target
        # dep tracking already decided not to re-link those ELFs, but
        # the mtime audit overruled it and dropped EVERY test in the
        # level. Today's Og-fp 89→0 regression was exactly this failure
        # mode (interacting with Bug #276's ADJCALLSTACK errors).
        #
        # Soften the audit: still emit a WARN for ELFs older than any
        # build input, but do NOT drop them. ninja's `.ninja_deps`
        # tracks per-source-file timestamps far more accurately than
        # this mtime comparison; if ninja didn't relink, the existing
        # ELF is still the right artefact to run against. Bug #279's
        # delta-vs-previous-run summary surfaces any genuinely stale
        # result as a regression in the per-level deltas.
        #
        # The existence check above (step 2) still catches link
        # failures — those go to `buildfail` and record as BUILDFAIL,
        # so a missing ELF is never silently treated as fresh.
        archive = _archive_path(bd)
        compilers = _compiler_binaries(bd)
        inputs = [(p, os.stat(p).st_mtime) for p in
                  ([str(archive)] if archive else []) + list(compilers)
                  if os.path.exists(p)]
        warn_count = 0
        for t in keep:
            elf = t["cmd"][0]
            elf_mtime = os.stat(elf).st_mtime
            stale_inputs = [(p, m) for p, m in inputs if m > elf_mtime]
            if stale_inputs:
                warn_count += 1
        if warn_count and verbose:
            print(f"preflight{tag}: WARN {warn_count} ELFs older than "
                  f"libc.a/compiler (ninja deemed re-link unnecessary; "
                  f"keeping — if a result moves vs prior bench, the "
                  f"delta column will surface it)",
                  flush=True)
    return keep, buildfail


def run_single_test(test_name, logbase, builddir=None):
    """Invoke meson test for one test; return the parsed result tuple or None.

    One-at-a-time execution lets the caller commit each result to the DB
    as it lands, so an interrupted run still preserves completed tests.
    The slight overhead (meson startup) is negligible next to usim runs.

    `builddir` overrides the module-level `BUILDDIR` for multi-builddir
    callers."""
    bd = builddir or BUILDDIR
    env = os.environ.copy()
    cap = SLOW_CAPS.get(test_name,
                        int(os.environ.get("USIM_TIMEOUT",
                                           DEFAULT_USIM_TIMEOUT)))
    env["USIM_TIMEOUT"] = str(cap)
    cmd = [
        "meson", "test",
        "-C", bd,
        "--no-rebuild",
        "--num-processes", "1",
        "--logbase", logbase,
        "--print-errorlogs",
        "-q",
        "-t", os.environ.get("MESON_TIMEOUT_MULTIPLIER", "10"),
        "--",
        test_name,
    ]
    subprocess.run(cmd, env=env, stdout=subprocess.DEVNULL,
                   stderr=subprocess.DEVNULL)
    log = f"{bd}/meson-logs/{logbase}.json"
    if not os.path.exists(log):
        return None
    for r in parse_meson_log(log):
        return r
    return None


def parse_meson_log(path):
    """Yield (name, result, returncode, stdout, stderr, duration, cycles) per test."""
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            r = json.loads(line)
            err = r.get("stderr", "")
            m = CYCLES_RE.search(err) if err else None
            cycles = int(m.group(1)) if m else None
            yield (
                r.get("name", "?"),
                r.get("result", "?"),
                r.get("returncode", -1),
                r.get("stdout", ""),
                err,
                r.get("duration", 0.0),
                cycles,
            )


def git_head(path):
    """Return short git SHA for the given path, or None if not a git repo."""
    try:
        out = subprocess.run(
            ["git", "-C", str(path), "rev-parse", "HEAD"],
            capture_output=True, text=True, check=True,
        )
        return out.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def llvm_commit_for_binary(repo, binary_path):
    """Return the SHA, suffixed with `+dirty` if the working tree has
    uncommitted tracked-file changes RIGHT NOW.

    Bug #191 originally added a second heuristic — flag dirty when the
    binary mtime postdates HEAD's commit time — to catch the
    'build-then-commit' case where the binary was built before the
    most recent commit was made.  Bug #236 retired that heuristic: in
    practice it fired on every post-commit rebuild (commit, then
    rebuild → mtime > commit-time → spurious +dirty for the rest of
    the session).  The `llvm_binary_mtime` column already records the
    binary's mtime independently, so analysts can correlate post hoc
    when needed; the SHA itself should be clean when the tree is
    clean.

    `binary_path` is unused now but retained to keep the call sites
    stable.
    """
    del binary_path  # retained for ABI; mtime check retired by #236
    sha = git_head(repo) or "unknown"
    dirty = ""
    # `git diff --quiet HEAD` checks tracked-file modifications
    # (working tree + index vs HEAD).  Untracked files like cfg/,
    # snap/ etc. don't count — exactly the right semantic.
    try:
        rc = subprocess.run(
            ["git", "-C", str(repo), "diff", "--quiet", "HEAD", "--"],
        ).returncode
        if rc != 0:
            dirty = "+dirty"
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return f"{sha}{dirty}"


def llvm_binary_mtime(binary_path):
    """Return Unix mtime of the llc binary, or None."""
    try:
        if binary_path and os.path.isfile(binary_path):
            return int(os.path.getmtime(binary_path))
    except OSError:
        pass
    return None


def find_llc():
    """Locate the llc binary on PATH so we can stat its mtime."""
    for entry in os.environ.get("PATH", "").split(os.pathsep):
        candidate = os.path.join(entry, "llc")
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def ensure_db(path):
    """Create the SQLite ledger if absent; return a connection."""
    path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(path))
    # WAL mode: needed when bench-parallel.sh runs multiple tallies
    # concurrently against the same ledger. Persists on the file, so
    # re-applying here is a no-op after the first call.
    conn.execute("PRAGMA journal_mode=WAL")
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS runs (
            run_id          INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp       TEXT NOT NULL,
            llvm_commit     TEXT,
            picolibc_commit TEXT,
            usim_commit     TEXT,
            host            TEXT,
            opt_level       TEXT
        );
        CREATE TABLE IF NOT EXISTS results (
            run_id       INTEGER NOT NULL REFERENCES runs(run_id),
            test_name    TEXT NOT NULL,
            suite        TEXT,
            status       TEXT NOT NULL,
            wall_seconds REAL,
            cycles       INTEGER,
            rc           INTEGER,
            opt_level    TEXT,
            PRIMARY KEY (run_id, test_name)
        );
        CREATE INDEX IF NOT EXISTS idx_results_test
            ON results(test_name, run_id);
        CREATE INDEX IF NOT EXISTS idx_results_opt
            ON results(opt_level, test_name);
    """)
    cols = {row[1] for row in conn.execute("PRAGMA table_info(runs)")}
    if "opt_level" not in cols:
        conn.execute("ALTER TABLE runs ADD COLUMN opt_level TEXT")
    if "llvm_binary_mtime" not in cols:  # bug #191
        conn.execute("ALTER TABLE runs ADD COLUMN llvm_binary_mtime INTEGER")
    cols = {row[1] for row in conn.execute("PRAGMA table_info(results)")}
    if "opt_level" not in cols:
        conn.execute("ALTER TABLE results ADD COLUMN opt_level TEXT")
    return conn


def insert_run_row(conn, opt_level):
    """Insert one fresh `runs` row tagged with `opt_level`; return run_id.

    Multi-builddir mode opens one connection and calls this once per
    level so each level gets its own ledger row, but all writes share a
    single SQLite handle (simpler and safe under WAL)."""
    usim_path = os.environ.get("USIM09BATCH") or "/Users/markmurray/GitHub/usim"
    usim_repo = Path(usim_path).parent if Path(usim_path).is_file() else Path(usim_path)
    llc_path = find_llc()  # bug #191
    run_row = (
        datetime.now(timezone.utc).isoformat(timespec="seconds"),
        llvm_commit_for_binary("/Users/markmurray/GitHub/llvm-mc6809", llc_path),
        git_head(REPO),
        git_head(str(usim_repo)),
        os.uname().nodename,
        opt_level,
        llvm_binary_mtime(llc_path),
    )
    cur = conn.cursor()
    cur.execute(
        "INSERT INTO runs (timestamp, llvm_commit, picolibc_commit, "
        "usim_commit, host, opt_level, llvm_binary_mtime) "
        "VALUES (?, ?, ?, ?, ?, ?, ?)",
        run_row,
    )
    conn.commit()
    return cur.lastrowid


def open_run(db_path, opt_level):
    """Open the ledger and insert a fresh `runs` row; return (conn, run_id).

    Single-builddir convenience wrapper around `ensure_db` + `insert_run_row`."""
    conn = ensure_db(db_path)
    return conn, insert_run_row(conn, opt_level)


def insert_result(conn, run_id, name, result, rc, dur, cycles, opt_level):
    """Insert one result row and commit immediately — durable per-test."""
    suite = name.split(" - ", 1)[0] if " - " in name else None
    conn.execute(
        "INSERT INTO results (run_id, test_name, suite, status, "
        "wall_seconds, cycles, rc, opt_level) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        (run_id, name, suite, result, dur, cycles, rc, opt_level),
    )
    conn.commit()


def prior_cycles(db_path, opt_level):
    """Map test_name -> last-recorded cycles for LPT scheduling.

    Filters by opt_level so a -O0 sweep doesn't pick up -Oz cycle
    counts (and vice versa). Tests not in the DB get 0, scheduling
    them last (cheap default)."""
    if not Path(db_path).exists():
        return {}
    conn = sqlite3.connect(str(db_path))
    try:
        if opt_level is None:
            cur = conn.execute(
                "SELECT test_name, cycles FROM results "
                "WHERE run_id = (SELECT MAX(run_id) FROM runs "
                "                WHERE opt_level IS NULL) "
                "AND cycles IS NOT NULL"
            )
        else:
            cur = conn.execute(
                "SELECT test_name, cycles FROM results "
                "WHERE run_id = (SELECT MAX(run_id) FROM runs "
                "                WHERE opt_level = ?) "
                "AND cycles IS NOT NULL",
                (opt_level,),
            )
        return dict(cur.fetchall())
    finally:
        conn.close()


def run_multi(args):
    """Multi-builddir mode: one shared parallel pool across all (level,
    test) pairs.

    Motivation: per-level sequential tallies make wall time = sum of
    per-level slowest-test times. With one flat pool, the slowest test
    in any level just blocks one worker — every other worker keeps
    grinding through the rest of the queue regardless of which level a
    test belongs to.

    Mechanics:
    - Parse the LEVEL:DIR list; preflight each builddir independently
      (each may need its own ninja refresh).
    - Tag every selected test with its (level, builddir).
    - LPT-sort across the union, using prior cycles per (test, level)
      so the longest tests start first.
    - Open one SQLite handle, insert one runs row per level, dispatch
      a single ThreadPoolExecutor of size --jobs over the flat queue.
      Each worker invokes meson test in the test's builddir; results
      get inserted under the matching level's run_id.
    """
    pairs = []
    for tok in args.multi.split(","):
        tok = tok.strip()
        if not tok:
            continue
        if ":" not in tok:
            print(f"--multi: malformed token {tok!r} (expected LEVEL:DIR)",
                  file=sys.stderr)
            return 2
        lvl, bd = tok.split(":", 1)
        if not os.path.isdir(bd):
            print(f"--multi: {lvl}: builddir {bd!r} not found",
                  file=sys.stderr)
            return 2
        pairs.append((lvl, bd))
    if not pairs:
        print("--multi: empty list", file=sys.stderr)
        return 2

    # Per-level preflight + test selection. SLOW_TESTS / FAKE_FS_TESTS
    # gating happens once here so it stays consistent across levels.
    queue = []
    buildfails = []  # Bug #237: list of (lvl, t) pairs to record as BUILDFAIL
    for lvl, bd in pairs:
        tests, level_buildfail = preflight_fresh_binaries(
            skip_ninja=args.no_preflight, builddir=bd,
        )
        # Apply the same SLOW/FAKE/--tests filters to buildfails as to
        # the runnable set: tests that would have been skipped anyway
        # don't need a BUILDFAIL noise row.
        if not args.slow:
            level_buildfail = [t for t in level_buildfail
                               if t["name"] not in SLOW_TESTS]
        if not args.slow and lvl.endswith("-mame"):
            level_buildfail = [t for t in level_buildfail
                               if t["name"] not in MAME_SLOW_TESTS]
        if not args.include_fake_fs:
            level_buildfail = [t for t in level_buildfail
                               if t["name"] not in FAKE_FS_TESTS]
        if args.tests:
            subs = [s for s in args.tests.split(",") if s]
            level_buildfail = [t for t in level_buildfail
                               if any(s in t["name"] for s in subs)]
        for t in level_buildfail:
            buildfails.append((lvl, t))
        if not args.slow:
            skipped = [t for t in tests if t["name"] in SLOW_TESTS]
            tests = [t for t in tests if t["name"] not in SLOW_TESTS]
            for t in skipped:
                print(f"[{lvl}] skipping {t['name']} (SLOW_TESTS; "
                      f"pass --slow to include)", flush=True)
        # Bug #204: under MAME, additional tests are too slow to run
        # routinely (~tens of minutes wall each). Skip them only when
        # the level is a -mame variant; --slow opts back in.
        if not args.slow and lvl.endswith("-mame"):
            skipped = [t for t in tests if t["name"] in MAME_SLOW_TESTS]
            tests = [t for t in tests if t["name"] not in MAME_SLOW_TESTS]
            for t in skipped:
                print(f"[{lvl}] skipping {t['name']} (MAME_SLOW_TESTS; "
                      f"too slow under MAME's emulation rate; "
                      f"pass --slow to include)", flush=True)
        if not args.include_fake_fs:
            skipped = [t for t in tests if t["name"] in FAKE_FS_TESTS]
            tests = [t for t in tests if t["name"] not in FAKE_FS_TESTS]
            for t in skipped:
                print(f"[{lvl}] skipping {t['name']} (FAKE_FS_TESTS; "
                      f"USim semihost has no real FS; pass "
                      f"--include-fake-fs to include)", flush=True)
        if args.tests:
            subs = [s for s in args.tests.split(",") if s]
            before = len(tests)
            tests = [t for t in tests
                     if any(s in t["name"] for s in subs)]
            print(f"[{lvl}] --tests filter: {before} → {len(tests)} "
                  f"({','.join(subs)})", flush=True)
        for t in tests:
            t["_level"] = lvl
            t["_builddir"] = bd
            queue.append(t)

    if not queue:
        print("no buildable test binaries found across any builddir",
              file=sys.stderr)
        return 1

    # LPT (longest processing time first) ordering across the union.
    # Each level's prior cycles map is independent so a slow test at
    # one level doesn't artificially front-load workers for another.
    if args.jobs > 1:
        prior_by_lvl = {lvl: prior_cycles(args.db, lvl)
                        for lvl, _ in pairs}
        queue.sort(
            key=lambda t: prior_by_lvl[t["_level"]].get(t["name"], 0),
            reverse=True,
        )

    conn = None
    run_ids = {}
    if args.record:
        conn = ensure_db(Path(args.db))
        # When --tests filtered the queue down, tag opt_level with a
        # "-quick" suffix so the cross-O summary's
        # `MAX(run_id) GROUP BY opt_level` doesn't shadow the most
        # recent FULL run at this level. Quick runs are still
        # recorded (so per-test cycle history works) but kept in a
        # separate taxonomy. (bug #168)
        suffix = "-quick" if args.tests else ""
        for lvl, _ in pairs:
            run_ids[lvl] = insert_run_row(conn, f"{lvl}{suffix}")
        print("recording to {} as {}".format(
            args.db,
            ", ".join(f"{lvl}{suffix}=run_id {run_ids[lvl]}"
                      for lvl, _ in pairs),
        ), flush=True)

    db_lock = threading.Lock()
    print_lock = threading.Lock()

    results = []  # (level, parsed)
    counts = Counter()  # keyed by (level, status)
    ftally = open(OUT, "w", buffering=1)
    flog = open(FAILLOG, "w", buffering=1)

    # Bug #237: record build-failed tests up front so the tally
    # includes them. They have no ELF so we can't run them; status
    # is BUILDFAIL with cycles=NULL and dur=0. Visible in the
    # per-level summary alongside OK/FAIL/SKIP/TIMEOUT. Recorded
    # before the pool starts, so no lock contention.
    if buildfails:
        for lvl, t in buildfails:
            counts[(lvl, "BUILDFAIL")] += 1
            results.append((lvl, (t["name"], "BUILDFAIL", -1, "", "", 0.0, None)))
            line = (f"[{lvl:5s}] BUILDFAIL      rc=-1     0.00s            "
                    f"{t['name']}")
            print(line, flush=True)
            ftally.write(line + "\n")
            if conn is not None:
                insert_result(conn, run_ids[lvl], t["name"],
                              "BUILDFAIL", -1, 0.0, None,
                              f"{lvl}{suffix}")
        print(f"[BUILDFAIL] recorded {len(buildfails)} link-failed "
              f"test(s) up front", flush=True)

    print(f"running {len(queue)} (level, test) pairs across "
          f"{len(pairs)} builddirs, --jobs {args.jobs}…", flush=True)

    def execute(t):
        name = t["name"]
        lvl = t["_level"]
        bd = t["_builddir"]
        # Per-level logbase prefix avoids meson-logs collisions when
        # the same test name appears in multiple builddirs (it always
        # does — every builddir runs the same test set).
        safe = re.sub(r"[^A-Za-z0-9._-]", "_", name)
        logbase = f"{LOGBASE}-{lvl}-{safe}"
        parsed = run_single_test(name, logbase, builddir=bd)
        if parsed is None:
            parsed = (name, "ERROR", -1, "", "", 0.0, None)
        pname, result, rc, out, err, dur, cycles = parsed
        if rc == USIM_CAP_RC and result == "FAIL":
            result = "TIMEOUT"
            parsed = (pname, result, rc, out, err, dur, cycles)
        return lvl, parsed

    def record(level_parsed, completed_idx, total):
        lvl, parsed = level_parsed
        pname, result, rc, out, err, dur, cycles = parsed
        results.append((lvl, parsed))
        counts[(lvl, result)] += 1
        cyc_str = f" cyc={cycles:>11d}" if cycles is not None else ""
        line = (f"[{lvl:5s}] {result:14s} rc={rc:<4d} {dur:6.2f}s"
                f"{cyc_str}  {pname}")
        with print_lock:
            print(f"[{completed_idx:>3}/{total}] {line}", flush=True)
            ftally.write(line + "\n")
            if result not in ("OK", "EXPECTEDFAIL", "SKIP"):
                flog.write("=" * 70 + "\n")
                flog.write(f"[{lvl}] {result}: {pname}  "
                           f"(rc={rc}, {dur:.2f}s)\n")
                flog.write("-" * 70 + "\n")
                if out:
                    flog.write("--- stdout ---\n" + out.rstrip() + "\n")
                if err:
                    flog.write("--- stderr ---\n" + err.rstrip() + "\n")
                flog.write("\n")
        if conn is not None:
            with db_lock:
                # Match the suffix used on the runs row (see insert_run_row
                # call above) so cross-O summary queries can filter quick
                # runs out symmetrically. (bug #168)
                rec_lvl = f"{lvl}-quick" if args.tests else lvl
                insert_result(conn, run_ids[lvl], pname, result, rc, dur,
                              cycles, rec_lvl)

    try:
        if args.jobs == 1:
            for i, t in enumerate(queue, 1):
                record(execute(t), i, len(queue))
        else:
            with ThreadPoolExecutor(max_workers=args.jobs) as pool:
                futures = [pool.submit(execute, t) for t in queue]
                for i, fut in enumerate(as_completed(futures), 1):
                    record(fut.result(), i, len(queue))
    finally:
        ftally.write("-" * 50 + "\n")
        per_level = {lvl: Counter() for lvl, _ in pairs}
        for (lvl, status), n in counts.items():
            per_level[lvl][status] += n
        for lvl, _ in pairs:
            ftally.write(f"[{lvl}]\n")
            for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL",
                      "UNEXPECTEDPASS", "ERROR", "TIMEOUT",
                      "BUILDFAIL"):
                if per_level[lvl].get(k):
                    ftally.write(f"  {k:14s} {per_level[lvl][k]}\n")
            ftally.write(f"  TOTAL          {sum(per_level[lvl].values())}\n")
        ftally.close()
        flog.close()
        if conn is not None:
            conn.close()

    for lvl, _ in pairs:
        parts = [f"{k}={per_level[lvl][k]}"
                 for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL",
                           "UNEXPECTEDPASS", "ERROR", "TIMEOUT",
                           "BUILDFAIL")
                 if per_level[lvl].get(k)]
        print(f"[{lvl:5s}] " + "  ".join(parts) +
              f"  TOTAL={sum(per_level[lvl].values())}")
    print(f"per-test: {OUT}")
    print(f"failure logs: {FAILLOG}")

    if args.record:
        for lvl, _ in pairs:
            cycle_total = sum(p[6] for l, p in results
                              if l == lvl and p[6] is not None)
            tests_with_cycles = sum(1 for l, p in results
                                    if l == lvl and p[6] is not None)
            print(f"  [{lvl}] recorded run_id={run_ids[lvl]} "
                  f"({tests_with_cycles} tests with cycles, "
                  f"total={cycle_total})")
    return 0


def main():
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[1])
    ap.add_argument("--record", action="store_true",
                    help="write cycles+status to the SQLite ledger")
    ap.add_argument("--db", default=os.environ.get("MC6809_BENCH_DB",
                                                   str(DEFAULT_DB)),
                    help=f"SQLite ledger path (default: {DEFAULT_DB})")
    ap.add_argument("--jobs", "-j", type=int, default=1,
                    help="parallel workers (default: 1). With --jobs >1, "
                         "tests are scheduled longest-first using cycle "
                         "counts from the most recent recorded run.")
    ap.add_argument("--opt-level", default=os.environ.get("MC6809_OPT_LEVEL"),
                    help="optimisation level tag to record alongside each "
                         "result row (e.g. O0, O1, O2, O3, Os, Oz). Used to "
                         "distinguish multi-O sweeps within the same DB. "
                         "Defaults to $MC6809_OPT_LEVEL or NULL.")
    ap.add_argument("--slow", action="store_true",
                    help="include tests in SLOW_TESTS (e.g. test-memmem, "
                         "~30 min wall). Off by default to keep routine "
                         "tallies fast.")
    ap.add_argument("--include-fake-fs", action="store_true",
                    help="include tests in FAKE_FS_TESTS (the 13 stdio/stat "
                         "tests that need real-FS semihost — fopen, fread, "
                         "fwrite, stat, etc.). USim's semihost is the "
                         "picolibc fake stub set, so these tests always FAIL "
                         "regardless of codegen. Skipped by default to keep "
                         "the bench ledger focused on codegen quality. Pass "
                         "this flag when actually measuring the semihost "
                         "layer or when USim has been extended with real "
                         "file I/O.")
    ap.add_argument("--no-preflight", action="store_true",
                    help="skip the pre-run ninja refresh of every test "
                         "binary. Use when you know the binaries are "
                         "already fresh (or when ninja would bring in "
                         "unwanted extra rebuilds). Off by default: the "
                         "preflight keeps the bench ledger honest by "
                         "making every recorded ELF match current source.")
    ap.add_argument("--tests", default=None, metavar="SUBSTR[,SUBSTR…]",
                    help="comma-separated list of substrings; only tests "
                         "whose name contains any listed substring will run. "
                         "Useful for fast-turnaround sanity-checks on a "
                         "single fix. Substring match is case-sensitive and "
                         "applies to the full meson test name "
                         "(e.g. 'newlib.string - picolibc:strcmp-1'); "
                         "unanchored, so 'snprintf' matches both snprintf "
                         "and nulprintf if both contain the substring. "
                         "Combine with --opt-level for a single-level run, "
                         "or with --multi for cross-level. Bug #168.")
    ap.add_argument("--multi", default=None, metavar="LEVEL:DIR,…",
                    help="multi-builddir mode: comma-separated list of "
                         "LEVEL:BUILDDIR pairs. Flattens every (level, "
                         "test) pair across all builddirs into a single "
                         "parallel pool sized by --jobs, so the longest-"
                         "running test never gates an entire opt-level "
                         "wave. Each level still gets its own runs row in "
                         "the ledger when --record is set. Overrides any "
                         "--opt-level / PICOLIBC_BUILDDIR settings.")
    args = ap.parse_args()

    if args.record:
        os.environ["USIM_CYCLES"] = "1"

    if args.multi:
        return run_multi(args)

    tests, buildfail = preflight_fresh_binaries(skip_ninja=args.no_preflight)
    # Bug #237: apply the same SLOW/FAKE/--tests filters to the
    # buildfail list so noise rows match the runnable set's policy.
    def _apply_filters(items):
        if not args.slow:
            items = [t for t in items if t["name"] not in SLOW_TESTS]
        if not args.slow and args.opt_level and args.opt_level.endswith("-mame"):
            items = [t for t in items if t["name"] not in MAME_SLOW_TESTS]
        if not args.include_fake_fs:
            items = [t for t in items if t["name"] not in FAKE_FS_TESTS]
        if args.tests:
            subs = [s for s in args.tests.split(",") if s]
            items = [t for t in items if any(s in t["name"] for s in subs)]
        return items
    if not args.slow:
        skipped = [t for t in tests if t["name"] in SLOW_TESTS]
        tests = [t for t in tests if t["name"] not in SLOW_TESTS]
        for t in skipped:
            print(f"skipping {t['name']} (SLOW_TESTS; pass --slow to include)",
                  flush=True)
    # Bug #204: MAME-only slow-test skip (mirrors the --multi path).
    if not args.slow and args.opt_level and args.opt_level.endswith("-mame"):
        skipped = [t for t in tests if t["name"] in MAME_SLOW_TESTS]
        tests = [t for t in tests if t["name"] not in MAME_SLOW_TESTS]
        for t in skipped:
            print(f"skipping {t['name']} (MAME_SLOW_TESTS; "
                  f"too slow under MAME's emulation rate; "
                  f"pass --slow to include)", flush=True)
    if not args.include_fake_fs:
        skipped = [t for t in tests if t["name"] in FAKE_FS_TESTS]
        tests = [t for t in tests if t["name"] not in FAKE_FS_TESTS]
        for t in skipped:
            print(f"skipping {t['name']} (FAKE_FS_TESTS; USim semihost has "
                  f"no real FS; pass --include-fake-fs to include)",
                  flush=True)
    if args.tests:
        subs = [s for s in args.tests.split(",") if s]
        before = len(tests)
        tests = [t for t in tests if any(s in t["name"] for s in subs)]
        print(f"--tests filter: {before} → {len(tests)} "
              f"({','.join(subs)})", flush=True)
    buildfail = _apply_filters(buildfail)
    if not tests and not buildfail:
        print("no buildable test binaries found", file=sys.stderr)
        return 1

    # LPT (longest processing time first) scheduling: feed the pool the
    # slowest tests first so they don't all stack on one worker at the
    # tail of the run. Unknown tests sort last (cycles default 0).
    if args.jobs > 1:
        prior = prior_cycles(args.db, args.opt_level)
        tests.sort(key=lambda t: prior.get(t["name"], 0), reverse=True)

    conn, run_id = (None, None)
    if args.record:
        # See run_multi() for the rationale on the -quick suffix.
        ol = args.opt_level
        if ol and args.tests:
            ol = f"{ol}-quick"
        conn, run_id = open_run(Path(args.db), ol)
        print(f"recording to {args.db} as run_id={run_id}", flush=True)

    # SQLite stdlib connection isn't thread-safe; serialise writes
    # behind a lock when running parallel. Print lock keeps the
    # interleaved per-test lines from fragmenting.
    db_lock = threading.Lock()
    print_lock = threading.Lock()

    results = []
    counts = Counter()
    # Open tally + failure log line-buffered so partial state is visible
    # even if the harness is interrupted.
    ftally = open(OUT, "w", buffering=1)
    flog = open(FAILLOG, "w", buffering=1)

    # Bug #237: record build-failed tests up front (no ELF to run).
    if buildfail:
        rec_ol = args.opt_level
        if rec_ol and args.tests:
            rec_ol = f"{rec_ol}-quick"
        for t in buildfail:
            counts["BUILDFAIL"] += 1
            results.append((t["name"], "BUILDFAIL", -1, "", "", 0.0, None))
            line = f"BUILDFAIL      rc=-1     0.00s            {t['name']}"
            print(line, flush=True)
            ftally.write(line + "\n")
            if conn is not None:
                insert_result(conn, run_id, t["name"], "BUILDFAIL",
                              -1, 0.0, None, rec_ol)
        print(f"[BUILDFAIL] recorded {len(buildfail)} link-failed "
              f"test(s) up front", flush=True)

    mode = "one-at-a-time" if args.jobs == 1 else f"{args.jobs}-at-a-time"
    print(f"running {len(tests)} tests {mode}…", flush=True)

    def execute(t):
        name = t["name"]
        safe = re.sub(r"[^A-Za-z0-9._-]", "_", name)
        logbase = f"{LOGBASE}-{safe}"
        parsed = run_single_test(name, logbase)
        if parsed is None:
            parsed = (name, "ERROR", -1, "", "", 0.0, None)
        pname, result, rc, out, err, dur, cycles = parsed
        if rc == USIM_CAP_RC and result == "FAIL":
            result = "TIMEOUT"
            parsed = (pname, result, rc, out, err, dur, cycles)
        return parsed

    def record(parsed, completed_idx, total):
        pname, result, rc, out, err, dur, cycles = parsed
        results.append(parsed)
        counts[result] += 1
        cyc_str = f" cyc={cycles:>11d}" if cycles is not None else ""
        line = f"{result:14s} rc={rc:<4d} {dur:6.2f}s{cyc_str}  {pname}"
        with print_lock:
            print(f"[{completed_idx:>2}/{total}] {line}", flush=True)
            ftally.write(line + "\n")
            if result not in ("OK", "EXPECTEDFAIL", "SKIP"):
                flog.write("=" * 70 + "\n")
                flog.write(f"{result}: {pname}  (rc={rc}, {dur:.2f}s)\n")
                flog.write("-" * 70 + "\n")
                if out:
                    flog.write("--- stdout ---\n" + out.rstrip() + "\n")
                if err:
                    flog.write("--- stderr ---\n" + err.rstrip() + "\n")
                flog.write("\n")
        if conn is not None:
            with db_lock:
                # Mirror the suffix used on the runs row above. (bug #168)
                rec_ol = args.opt_level
                if rec_ol and args.tests:
                    rec_ol = f"{rec_ol}-quick"
                insert_result(conn, run_id, pname, result, rc, dur, cycles,
                              rec_ol)

    try:
        if args.jobs == 1:
            for i, t in enumerate(tests, 1):
                record(execute(t), i, len(tests))
        else:
            with ThreadPoolExecutor(max_workers=args.jobs) as pool:
                futures = [pool.submit(execute, t) for t in tests]
                for i, fut in enumerate(as_completed(futures), 1):
                    record(fut.result(), i, len(tests))
    finally:
        ftally.write("-" * 50 + "\n")
        for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL", "UNEXPECTEDPASS",
                  "ERROR", "TIMEOUT", "BUILDFAIL"):
            if counts.get(k):
                ftally.write(f"{k:14s} {counts[k]}\n")
        ftally.write(f"TOTAL          {sum(counts.values())}\n")
        ftally.close()
        flog.close()
        if conn is not None:
            conn.close()

    parts = [f"{k}={counts[k]}"
             for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL",
                       "UNEXPECTEDPASS", "ERROR", "TIMEOUT",
                       "BUILDFAIL")
             if counts.get(k)]
    print("  ".join(parts) + f"  TOTAL={sum(counts.values())}")
    print(f"per-test: {OUT}")
    print(f"failure logs: {FAILLOG}")

    if args.record:
        cycle_total = sum(r[6] for r in results if r[6] is not None)
        tests_with_cycles = sum(1 for r in results if r[6] is not None)
        print(f"recorded run_id={run_id} to {args.db} "
              f"({tests_with_cycles} tests with cycles, total={cycle_total})")
    return 0


if __name__ == "__main__":
    sys.exit(main())