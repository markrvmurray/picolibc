#!/usr/bin/env python3
"""
Run picolibc test binaries via meson, honouring meson's exit-code
semantics (rc=77 SKIP, rc=99 ERROR, should_fail inversion, etc).

Replaces an earlier hand-rolled bash tally that misclassified rc=77
as FAIL and ignored should_fail. Classification is delegated to
`meson test` itself — the source of truth — and we only filter out
tests whose binaries don't currently build, so compile gaps don't
take out the whole run.

Outputs:
  /tmp/picolibc-results.txt   — one line per test, plus tally
  /tmp/picolibc-failures.log  — stdout+stderr of every non-OK test

Preflight: the harness batches `ninja` over every candidate test
binary before running any test, so each ELF matches the current
source. Without this, a source fix that wasn't followed by a rebuild
could be recorded as FAIL against the new git SHA — polluting the
bench ledger. Disable with --no-preflight. NOTE: ninja only tracks
source files, not the compiler binary; a fresh `llc`/`clang` with
unchanged picolibc .c still leaves stale .c.o on disk. Delete .c.o
separately when iterating on backend code (see bench-session skill).

With --record, also writes each run to
  ~/Documents/mc6809-bench/results.sqlite
so cycle counts can be tracked over time. Requires USIM_CYCLES=1
(set automatically) so usim09batch emits cycles=<N> on stderr.

Environment overrides:
  PICOLIBC_BUILDDIR   build directory (default: <repo>/builddir-mc6809)
  USIM09BATCH         USim binary
  LLVM_OBJCOPY        llvm-objcopy
  LLVM_NM             llvm-nm
  MC6809_BENCH_DB     override SQLite path (default: ~/Documents/
                      mc6809-bench/results.sqlite)
"""

import argparse
import json
import os
import re
import sqlite3
import subprocess
import sys
import threading
from collections import Counter
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime, timezone
from pathlib import Path

REPO     = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
BUILDDIR = os.environ.get("PICOLIBC_BUILDDIR", f"{REPO}/builddir-mc6809")

OUT     = "/tmp/picolibc-results.txt"
FAILLOG = "/tmp/picolibc-failures.log"
LOGBASE = "mc6809-tally"

DEFAULT_DB = Path.home() / "Documents" / "mc6809-bench" / "results.sqlite"

CYCLES_RE = re.compile(r"^cycles=(\d+)\s*$", re.MULTILINE)

# usim09batch exits 124 (GNU `timeout(1)` convention) when --timeout=N
# is hit. meson only sees a non-zero rc and reports FAIL; reclassify
# here so cap-hits appear as TIMEOUT in the ledger instead of polluting
# the FAIL bucket. Bumping USIM_TIMEOUT is the other half of bug #131.
USIM_CAP_RC = 124

# Per-test usim instruction caps. Keys are the bare test name as stored
# in meson's intro-tests.json (what the harness passes to `meson test`);
# meson itself renders a fuller "suite - project:name" form in its logs,
# but that form is derived only after the fact. Measured values from
# run_id=7/9 with ~2x headroom. A single global USIM_TIMEOUT is wrong:
# tight on the slow-but-correct outliers (they trip the cap and get
# misclassified as TIMEOUT) yet far too generous for the fast majority
# (a genuine hang in any fast test sleeps for the slow-test budget).
# This table lets each known-slow test set its own ceiling while
# everything else keeps the tight default. Source of truth is
# reference_slow_test_budgets.md.
SLOW_CAPS = {
    "strcmp-1":     5_000_000_000,
    "test-memset":  3_000_000_000,
    "test-memchr": 25_000_000_000,
    "test-memmem": 80_000_000_000,
}

# Tests that are genuinely too slow for routine tallies (>10 min wall).
# Skipped by default; included only with --slow. Keeps the default
# tally fast without losing the ability to run them when needed.
SLOW_TESTS = {
    "test-memmem",
}

# Default usim cap for tests not in SLOW_CAPS. Matches run-mc6809's
# own fallback so behaviour is identical between single-test and
# tally invocations. Override via USIM_TIMEOUT env if callers really
# need a different baseline for all tests.
DEFAULT_USIM_TIMEOUT = 2_000_000_000


def try_noflash_relink(target_path, builddir=None):
    """Relink a test that overflowed flash using the no-flash linker
    script + crt0. Returns True if the binary now exists and is
    executable.

    When picolibc's default link script (16 KB flash + 16 KB RAM) can't
    fit the .text, meson leaves the test binary missing and meson-test
    quietly drops it. But the 6809 can access 64 KB linearly — the
    picolibc_noflash.ld script + crt0-noflash-semihost make the whole
    address space RAM, which fits all current tests comfortably. To
    keep big tests (qsort, string, strtol, …) in the campaign, we
    substitute the no-flash variants and re-link on the fly instead of
    dropping the test.

    The .o dependencies are unchanged between flash and no-flash
    configurations, so we can reuse them — only the crt0 object and
    the linker script differ.

    `builddir` overrides the module-level `BUILDDIR` for multi-builddir
    callers. Defaults to `BUILDDIR` for the legacy single-builddir
    code path."""
    bd = builddir or BUILDDIR
    target = os.path.relpath(target_path, bd)
    try:
        out = subprocess.run(
            ["ninja", "-C", bd, "-t", "commands", target],
            capture_output=True, text=True, check=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False
    lines = [l for l in out.stdout.splitlines() if l.strip()]
    if not lines:
        return False
    link_cmd = lines[-1]
    if " -T " not in link_cmd:
        return False  # not a link step we recognise
    link_cmd = link_cmd.replace(
        "picocrt/crt0-semihost.o.p/",
        "picocrt/crt0-noflash-semihost.o.p/",
    )
    link_cmd = link_cmd.replace(
        "picocrt/crt0-hosted.o.p/",
        "picocrt/crt0-noflash-hosted.o.p/",
    )
    link_cmd = link_cmd.replace("/picolibc.ld", "/picolibc_noflash.ld")
    rc = subprocess.run(link_cmd, shell=True, cwd=bd,
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL).returncode
    return (rc == 0 and os.path.isfile(target_path)
            and os.access(target_path, os.X_OK))


def preflight_fresh_binaries(skip_ninja=False, verbose=True, builddir=None):
    """Read intro-tests.json, refresh every test binary, return the
    subset that now exists and is executable.

    Without the refresh, `meson test --no-rebuild` runs whatever ELF
    happens to be on disk — even if its source has been edited since
    the last link. Run_ids 13/14/15 recorded `snprintf` = FAIL against
    picolibc `4092ca7a1` (which includes the gate fix `18d9bb4d2`)
    because the on-disk `snprintf.elf` predated that commit; a later
    rebuild produced an ELF that passes. The preflight prevents that
    class of phantom regression.

    Flash tests go through `ninja -k 0` in one batch; ninja's
    `.ninja_deps` tracking handles staleness, and `-k 0` keeps the
    batch going past permanently-broken FP-gated targets (see
    `project_fp_not_enabled.md`). Flash-overflow tests get the same
    noflash relink path as before — their link command isn't part of
    ninja's graph, so ninja can't refresh them.

    `skip_ninja=True` disables the refresh step (for callers that know
    their binaries are fresh, e.g. immediately after a manual
    `cmake --build`). Still runs the existence check and noflash
    fallback.

    `builddir` overrides the module-level `BUILDDIR` for multi-builddir
    callers; legacy single-builddir callers leave it None.

    CAVEAT: ninja tracks source mtimes, not compiler-binary mtimes.
    If `llc`/`clang` was rebuilt but no picolibc source changed, the
    stale `.c.o` files won't be regenerated by this preflight. Manual
    `.c.o` deletion is still required after a backend rebuild (see
    `feedback_ninja_compiler_dep.md`)."""
    bd = builddir or BUILDDIR
    with open(f"{bd}/meson-info/intro-tests.json") as f:
        tests = json.load(f)
    cands = [t for t in tests
             if "picolibc:headers" not in t["suite"] and t["cmd"]]
    if not skip_ninja:
        targets = [os.path.relpath(t["cmd"][0], bd) for t in cands]
        if verbose:
            tag = f" [{os.path.basename(bd)}]" if builddir else ""
            print(f"preflight{tag}: ninja-refresh {len(targets)} test binaries…",
                  flush=True)
        try:
            subprocess.run(
                ["ninja", "-C", bd, "-k", "0"] + targets,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                check=False,
            )
        except FileNotFoundError:
            if verbose:
                print("preflight: ninja not found on PATH; "
                      "skipping refresh (recorded tally may use stale ELFs)",
                      flush=True)
    keep = []
    for t in cands:
        cmd0 = t["cmd"][0]
        if os.path.isfile(cmd0) and os.access(cmd0, os.X_OK):
            keep.append(t)
        elif try_noflash_relink(cmd0, builddir=bd):
            t["_noflash"] = True
            keep.append(t)
    return keep


def run_single_test(test_name, logbase, builddir=None):
    """Invoke meson test for one test; return the parsed result tuple or None.

    One-at-a-time execution lets the caller commit each result to the DB
    as it lands, so an interrupted run still preserves completed tests.
    The slight overhead (meson startup) is negligible next to usim runs.

    `builddir` overrides the module-level `BUILDDIR` for multi-builddir
    callers."""
    bd = builddir or BUILDDIR
    env = os.environ.copy()
    cap = SLOW_CAPS.get(test_name,
                        int(os.environ.get("USIM_TIMEOUT",
                                           DEFAULT_USIM_TIMEOUT)))
    env["USIM_TIMEOUT"] = str(cap)
    cmd = [
        "meson", "test",
        "-C", bd,
        "--no-rebuild",
        "--num-processes", "1",
        "--logbase", logbase,
        "--print-errorlogs",
        "-q",
        "-t", os.environ.get("MESON_TIMEOUT_MULTIPLIER", "10"),
        "--",
        test_name,
    ]
    subprocess.run(cmd, env=env, stdout=subprocess.DEVNULL,
                   stderr=subprocess.DEVNULL)
    log = f"{bd}/meson-logs/{logbase}.json"
    if not os.path.exists(log):
        return None
    for r in parse_meson_log(log):
        return r
    return None


def parse_meson_log(path):
    """Yield (name, result, returncode, stdout, stderr, duration, cycles) per test."""
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            r = json.loads(line)
            err = r.get("stderr", "")
            m = CYCLES_RE.search(err) if err else None
            cycles = int(m.group(1)) if m else None
            yield (
                r.get("name", "?"),
                r.get("result", "?"),
                r.get("returncode", -1),
                r.get("stdout", ""),
                err,
                r.get("duration", 0.0),
                cycles,
            )


def git_head(path):
    """Return short git SHA for the given path, or None if not a git repo."""
    try:
        out = subprocess.run(
            ["git", "-C", str(path), "rev-parse", "HEAD"],
            capture_output=True, text=True, check=True,
        )
        return out.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def ensure_db(path):
    """Create the SQLite ledger if absent; return a connection."""
    path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(path))
    # WAL mode: needed when bench-parallel.sh runs multiple tallies
    # concurrently against the same ledger. Persists on the file, so
    # re-applying here is a no-op after the first call.
    conn.execute("PRAGMA journal_mode=WAL")
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS runs (
            run_id          INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp       TEXT NOT NULL,
            llvm_commit     TEXT,
            picolibc_commit TEXT,
            usim_commit     TEXT,
            host            TEXT,
            opt_level       TEXT
        );
        CREATE TABLE IF NOT EXISTS results (
            run_id       INTEGER NOT NULL REFERENCES runs(run_id),
            test_name    TEXT NOT NULL,
            suite        TEXT,
            status       TEXT NOT NULL,
            wall_seconds REAL,
            cycles       INTEGER,
            rc           INTEGER,
            opt_level    TEXT,
            PRIMARY KEY (run_id, test_name)
        );
        CREATE INDEX IF NOT EXISTS idx_results_test
            ON results(test_name, run_id);
        CREATE INDEX IF NOT EXISTS idx_results_opt
            ON results(opt_level, test_name);
    """)
    cols = {row[1] for row in conn.execute("PRAGMA table_info(runs)")}
    if "opt_level" not in cols:
        conn.execute("ALTER TABLE runs ADD COLUMN opt_level TEXT")
    cols = {row[1] for row in conn.execute("PRAGMA table_info(results)")}
    if "opt_level" not in cols:
        conn.execute("ALTER TABLE results ADD COLUMN opt_level TEXT")
    return conn


def insert_run_row(conn, opt_level):
    """Insert one fresh `runs` row tagged with `opt_level`; return run_id.

    Multi-builddir mode opens one connection and calls this once per
    level so each level gets its own ledger row, but all writes share a
    single SQLite handle (simpler and safe under WAL)."""
    usim_path = os.environ.get("USIM09BATCH") or "/Users/markmurray/GitHub/usim"
    usim_repo = Path(usim_path).parent if Path(usim_path).is_file() else Path(usim_path)
    run_row = (
        datetime.now(timezone.utc).isoformat(timespec="seconds"),
        git_head("/Users/markmurray/GitHub/llvm-mc6809"),
        git_head(REPO),
        git_head(str(usim_repo)),
        os.uname().nodename,
        opt_level,
    )
    cur = conn.cursor()
    cur.execute(
        "INSERT INTO runs (timestamp, llvm_commit, picolibc_commit, "
        "usim_commit, host, opt_level) VALUES (?, ?, ?, ?, ?, ?)",
        run_row,
    )
    conn.commit()
    return cur.lastrowid


def open_run(db_path, opt_level):
    """Open the ledger and insert a fresh `runs` row; return (conn, run_id).

    Single-builddir convenience wrapper around `ensure_db` + `insert_run_row`."""
    conn = ensure_db(db_path)
    return conn, insert_run_row(conn, opt_level)


def insert_result(conn, run_id, name, result, rc, dur, cycles, opt_level):
    """Insert one result row and commit immediately — durable per-test."""
    suite = name.split(" - ", 1)[0] if " - " in name else None
    conn.execute(
        "INSERT INTO results (run_id, test_name, suite, status, "
        "wall_seconds, cycles, rc, opt_level) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        (run_id, name, suite, result, dur, cycles, rc, opt_level),
    )
    conn.commit()


def prior_cycles(db_path, opt_level):
    """Map test_name -> last-recorded cycles for LPT scheduling.

    Filters by opt_level so a -O0 sweep doesn't pick up -Oz cycle
    counts (and vice versa). Tests not in the DB get 0, scheduling
    them last (cheap default)."""
    if not Path(db_path).exists():
        return {}
    conn = sqlite3.connect(str(db_path))
    try:
        if opt_level is None:
            cur = conn.execute(
                "SELECT test_name, cycles FROM results "
                "WHERE run_id = (SELECT MAX(run_id) FROM runs "
                "                WHERE opt_level IS NULL) "
                "AND cycles IS NOT NULL"
            )
        else:
            cur = conn.execute(
                "SELECT test_name, cycles FROM results "
                "WHERE run_id = (SELECT MAX(run_id) FROM runs "
                "                WHERE opt_level = ?) "
                "AND cycles IS NOT NULL",
                (opt_level,),
            )
        return dict(cur.fetchall())
    finally:
        conn.close()


def run_multi(args):
    """Multi-builddir mode: one shared parallel pool across all (level,
    test) pairs.

    Motivation: per-level sequential tallies make wall time = sum of
    per-level slowest-test times. With one flat pool, the slowest test
    in any level just blocks one worker — every other worker keeps
    grinding through the rest of the queue regardless of which level a
    test belongs to.

    Mechanics:
    - Parse the LEVEL:DIR list; preflight each builddir independently
      (each may need its own ninja refresh / noflash relinks).
    - Tag every selected test with its (level, builddir).
    - LPT-sort across the union, using prior cycles per (test, level)
      so the longest tests start first.
    - Open one SQLite handle, insert one runs row per level, dispatch
      a single ThreadPoolExecutor of size --jobs over the flat queue.
      Each worker invokes meson test in the test's builddir; results
      get inserted under the matching level's run_id.
    """
    pairs = []
    for tok in args.multi.split(","):
        tok = tok.strip()
        if not tok:
            continue
        if ":" not in tok:
            print(f"--multi: malformed token {tok!r} (expected LEVEL:DIR)",
                  file=sys.stderr)
            return 2
        lvl, bd = tok.split(":", 1)
        if not os.path.isdir(bd):
            print(f"--multi: {lvl}: builddir {bd!r} not found",
                  file=sys.stderr)
            return 2
        pairs.append((lvl, bd))
    if not pairs:
        print("--multi: empty list", file=sys.stderr)
        return 2

    # Per-level preflight + test selection. SLOW_TESTS gating happens
    # once here so it stays consistent across levels.
    queue = []
    noflash_set = set()  # (level, name)
    for lvl, bd in pairs:
        tests = preflight_fresh_binaries(
            skip_ninja=args.no_preflight, builddir=bd,
        )
        if not args.slow:
            skipped = [t for t in tests if t["name"] in SLOW_TESTS]
            tests = [t for t in tests if t["name"] not in SLOW_TESTS]
            for t in skipped:
                print(f"[{lvl}] skipping {t['name']} (SLOW_TESTS; "
                      f"pass --slow to include)", flush=True)
        for t in tests:
            t["_level"] = lvl
            t["_builddir"] = bd
            if t.get("_noflash"):
                noflash_set.add((lvl, t["name"]))
            queue.append(t)

    if not queue:
        print("no buildable test binaries found across any builddir",
              file=sys.stderr)
        return 1

    # LPT (longest processing time first) ordering across the union.
    # Each level's prior cycles map is independent so a slow test at
    # one level doesn't artificially front-load workers for another.
    if args.jobs > 1:
        prior_by_lvl = {lvl: prior_cycles(args.db, lvl)
                        for lvl, _ in pairs}
        queue.sort(
            key=lambda t: prior_by_lvl[t["_level"]].get(t["name"], 0),
            reverse=True,
        )

    conn = None
    run_ids = {}
    if args.record:
        conn = ensure_db(Path(args.db))
        for lvl, _ in pairs:
            run_ids[lvl] = insert_run_row(conn, lvl)
        print("recording to {} as {}".format(
            args.db,
            ", ".join(f"{lvl}=run_id {run_ids[lvl]}" for lvl, _ in pairs),
        ), flush=True)

    db_lock = threading.Lock()
    print_lock = threading.Lock()

    results = []  # (level, parsed)
    counts = Counter()  # keyed by (level, status)
    ftally = open(OUT, "w", buffering=1)
    flog = open(FAILLOG, "w", buffering=1)
    print(f"running {len(queue)} (level, test) pairs across "
          f"{len(pairs)} builddirs, --jobs {args.jobs}…", flush=True)

    def execute(t):
        name = t["name"]
        lvl = t["_level"]
        bd = t["_builddir"]
        # Per-level logbase prefix avoids meson-logs collisions when
        # the same test name appears in multiple builddirs (it always
        # does — every builddir runs the same test set).
        safe = re.sub(r"[^A-Za-z0-9._-]", "_", name)
        logbase = f"{LOGBASE}-{lvl}-{safe}"
        parsed = run_single_test(name, logbase, builddir=bd)
        if parsed is None:
            parsed = (name, "ERROR", -1, "", "", 0.0, None)
        pname, result, rc, out, err, dur, cycles = parsed
        if rc == USIM_CAP_RC and result == "FAIL":
            result = "TIMEOUT"
            parsed = (pname, result, rc, out, err, dur, cycles)
        return lvl, parsed

    def record(level_parsed, completed_idx, total):
        lvl, parsed = level_parsed
        pname, result, rc, out, err, dur, cycles = parsed
        results.append((lvl, parsed))
        counts[(lvl, result)] += 1
        cyc_str = f" cyc={cycles:>11d}" if cycles is not None else ""
        nf = " [NOFLASH]" if (lvl, pname) in noflash_set \
             or (lvl, pname.split(" - ", 1)[-1]) in noflash_set else ""
        line = (f"[{lvl:5s}] {result:14s} rc={rc:<4d} {dur:6.2f}s"
                f"{cyc_str}  {pname}{nf}")
        with print_lock:
            print(f"[{completed_idx:>3}/{total}] {line}", flush=True)
            ftally.write(line + "\n")
            if result not in ("OK", "EXPECTEDFAIL", "SKIP"):
                flog.write("=" * 70 + "\n")
                flog.write(f"[{lvl}] {result}: {pname}  "
                           f"(rc={rc}, {dur:.2f}s)\n")
                flog.write("-" * 70 + "\n")
                if out:
                    flog.write("--- stdout ---\n" + out.rstrip() + "\n")
                if err:
                    flog.write("--- stderr ---\n" + err.rstrip() + "\n")
                flog.write("\n")
        if conn is not None:
            with db_lock:
                insert_result(conn, run_ids[lvl], pname, result, rc, dur,
                              cycles, lvl)

    try:
        if args.jobs == 1:
            for i, t in enumerate(queue, 1):
                record(execute(t), i, len(queue))
        else:
            with ThreadPoolExecutor(max_workers=args.jobs) as pool:
                futures = [pool.submit(execute, t) for t in queue]
                for i, fut in enumerate(as_completed(futures), 1):
                    record(fut.result(), i, len(queue))
    finally:
        ftally.write("-" * 50 + "\n")
        per_level = {lvl: Counter() for lvl, _ in pairs}
        for (lvl, status), n in counts.items():
            per_level[lvl][status] += n
        for lvl, _ in pairs:
            ftally.write(f"[{lvl}]\n")
            for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL",
                      "UNEXPECTEDPASS", "ERROR", "TIMEOUT"):
                if per_level[lvl].get(k):
                    ftally.write(f"  {k:14s} {per_level[lvl][k]}\n")
            ftally.write(f"  TOTAL          {sum(per_level[lvl].values())}\n")
        ftally.close()
        flog.close()
        if conn is not None:
            conn.close()

    for lvl, _ in pairs:
        parts = [f"{k}={per_level[lvl][k]}"
                 for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL",
                           "UNEXPECTEDPASS", "ERROR", "TIMEOUT")
                 if per_level[lvl].get(k)]
        print(f"[{lvl:5s}] " + "  ".join(parts) +
              f"  TOTAL={sum(per_level[lvl].values())}")
    print(f"per-test: {OUT}")
    print(f"failure logs: {FAILLOG}")

    if args.record:
        for lvl, _ in pairs:
            cycle_total = sum(p[6] for l, p in results
                              if l == lvl and p[6] is not None)
            tests_with_cycles = sum(1 for l, p in results
                                    if l == lvl and p[6] is not None)
            print(f"  [{lvl}] recorded run_id={run_ids[lvl]} "
                  f"({tests_with_cycles} tests with cycles, "
                  f"total={cycle_total})")
    return 0


def main():
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[1])
    ap.add_argument("--record", action="store_true",
                    help="write cycles+status to the SQLite ledger")
    ap.add_argument("--db", default=os.environ.get("MC6809_BENCH_DB",
                                                   str(DEFAULT_DB)),
                    help=f"SQLite ledger path (default: {DEFAULT_DB})")
    ap.add_argument("--jobs", "-j", type=int, default=1,
                    help="parallel workers (default: 1). With --jobs >1, "
                         "tests are scheduled longest-first using cycle "
                         "counts from the most recent recorded run.")
    ap.add_argument("--opt-level", default=os.environ.get("MC6809_OPT_LEVEL"),
                    help="optimisation level tag to record alongside each "
                         "result row (e.g. O0, O1, O2, O3, Os, Oz). Used to "
                         "distinguish multi-O sweeps within the same DB. "
                         "Defaults to $MC6809_OPT_LEVEL or NULL.")
    ap.add_argument("--slow", action="store_true",
                    help="include tests in SLOW_TESTS (e.g. test-memmem, "
                         "~30 min wall). Off by default to keep routine "
                         "tallies fast.")
    ap.add_argument("--no-preflight", action="store_true",
                    help="skip the pre-run ninja refresh of every test "
                         "binary. Use when you know the binaries are "
                         "already fresh (or when ninja would bring in "
                         "unwanted extra rebuilds). Off by default: the "
                         "preflight keeps the bench ledger honest by "
                         "making every recorded ELF match current source.")
    ap.add_argument("--multi", default=None, metavar="LEVEL:DIR,…",
                    help="multi-builddir mode: comma-separated list of "
                         "LEVEL:BUILDDIR pairs. Flattens every (level, "
                         "test) pair across all builddirs into a single "
                         "parallel pool sized by --jobs, so the longest-"
                         "running test never gates an entire opt-level "
                         "wave. Each level still gets its own runs row in "
                         "the ledger when --record is set. Overrides any "
                         "--opt-level / PICOLIBC_BUILDDIR settings.")
    args = ap.parse_args()

    if args.record:
        os.environ["USIM_CYCLES"] = "1"

    if args.multi:
        return run_multi(args)

    tests = preflight_fresh_binaries(skip_ninja=args.no_preflight)
    if not args.slow:
        skipped = [t for t in tests if t["name"] in SLOW_TESTS]
        tests = [t for t in tests if t["name"] not in SLOW_TESTS]
        for t in skipped:
            print(f"skipping {t['name']} (SLOW_TESTS; pass --slow to include)",
                  flush=True)
    if not tests:
        print("no buildable test binaries found", file=sys.stderr)
        return 1

    # LPT (longest processing time first) scheduling: feed the pool the
    # slowest tests first so they don't all stack on one worker at the
    # tail of the run. Unknown tests sort last (cycles default 0).
    if args.jobs > 1:
        prior = prior_cycles(args.db, args.opt_level)
        tests.sort(key=lambda t: prior.get(t["name"], 0), reverse=True)

    conn, run_id = (None, None)
    if args.record:
        conn, run_id = open_run(Path(args.db), args.opt_level)
        print(f"recording to {args.db} as run_id={run_id}", flush=True)

    # SQLite stdlib connection isn't thread-safe; serialise writes
    # behind a lock when running parallel. Print lock keeps the
    # interleaved per-test lines from fragmenting.
    db_lock = threading.Lock()
    print_lock = threading.Lock()

    results = []
    counts = Counter()
    # Open tally + failure log line-buffered so partial state is visible
    # even if the harness is interrupted.
    ftally = open(OUT, "w", buffering=1)
    flog = open(FAILLOG, "w", buffering=1)
    mode = "one-at-a-time" if args.jobs == 1 else f"{args.jobs}-at-a-time"
    print(f"running {len(tests)} tests {mode}…", flush=True)

    noflash_tests = {t["name"] for t in tests if t.get("_noflash")}

    def execute(t):
        name = t["name"]
        safe = re.sub(r"[^A-Za-z0-9._-]", "_", name)
        logbase = f"{LOGBASE}-{safe}"
        parsed = run_single_test(name, logbase)
        if parsed is None:
            parsed = (name, "ERROR", -1, "", "", 0.0, None)
        pname, result, rc, out, err, dur, cycles = parsed
        if rc == USIM_CAP_RC and result == "FAIL":
            result = "TIMEOUT"
            parsed = (pname, result, rc, out, err, dur, cycles)
        return parsed

    def record(parsed, completed_idx, total):
        pname, result, rc, out, err, dur, cycles = parsed
        results.append(parsed)
        counts[result] += 1
        cyc_str = f" cyc={cycles:>11d}" if cycles is not None else ""
        nf = " [NOFLASH]" if pname.split(" - ", 1)[-1] in noflash_tests \
             or pname in noflash_tests else ""
        line = f"{result:14s} rc={rc:<4d} {dur:6.2f}s{cyc_str}  {pname}{nf}"
        with print_lock:
            print(f"[{completed_idx:>2}/{total}] {line}", flush=True)
            ftally.write(line + "\n")
            if result not in ("OK", "EXPECTEDFAIL", "SKIP"):
                flog.write("=" * 70 + "\n")
                flog.write(f"{result}: {pname}  (rc={rc}, {dur:.2f}s)\n")
                flog.write("-" * 70 + "\n")
                if out:
                    flog.write("--- stdout ---\n" + out.rstrip() + "\n")
                if err:
                    flog.write("--- stderr ---\n" + err.rstrip() + "\n")
                flog.write("\n")
        if conn is not None:
            with db_lock:
                insert_result(conn, run_id, pname, result, rc, dur, cycles,
                              args.opt_level)

    try:
        if args.jobs == 1:
            for i, t in enumerate(tests, 1):
                record(execute(t), i, len(tests))
        else:
            with ThreadPoolExecutor(max_workers=args.jobs) as pool:
                futures = [pool.submit(execute, t) for t in tests]
                for i, fut in enumerate(as_completed(futures), 1):
                    record(fut.result(), i, len(tests))
    finally:
        ftally.write("-" * 50 + "\n")
        for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL", "UNEXPECTEDPASS",
                  "ERROR", "TIMEOUT"):
            if counts.get(k):
                ftally.write(f"{k:14s} {counts[k]}\n")
        ftally.write(f"TOTAL          {sum(counts.values())}\n")
        ftally.close()
        flog.close()
        if conn is not None:
            conn.close()

    parts = [f"{k}={counts[k]}"
             for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL",
                       "UNEXPECTEDPASS", "ERROR", "TIMEOUT")
             if counts.get(k)]
    print("  ".join(parts) + f"  TOTAL={sum(counts.values())}")
    print(f"per-test: {OUT}")
    print(f"failure logs: {FAILLOG}")

    if args.record:
        cycle_total = sum(r[6] for r in results if r[6] is not None)
        tests_with_cycles = sum(1 for r in results if r[6] is not None)
        print(f"recorded run_id={run_id} to {args.db} "
              f"({tests_with_cycles} tests with cycles, total={cycle_total})")
    return 0


if __name__ == "__main__":
    sys.exit(main())