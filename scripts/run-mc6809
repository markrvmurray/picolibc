#!/bin/sh
#
# run-mc6809 — picolibc test runner for MC6809 (usim09batch)
#
# Usage: run-mc6809 <elf> [--stdin "string"] [--args "args"]
#
# Converts ELF to Intel HEX and runs via usim09batch.
# Exit code from the simulated program's halt device write.
#

USIM="${USIM09BATCH:-usim09batch}"
OBJCOPY="${LLVM_OBJCOPY:-llvm-objcopy}"
NM="${LLVM_NM:-llvm-nm}"

# select the program
elf="$1"
shift

stdin=""
args=""
done=0
while [ $# -gt 0 -a $done -eq 0 ]; do
  case "$1" in
    --stdin)
      stdin="$2"
      shift 2
      ;;
    --args)
      args="$2"
      shift 2
      ;;
    *)
      done=1
      ;;
  esac
done

if [ -z "$elf" ]; then
  echo "usage: run-mc6809 <elf> [--stdin string] [--args string]" >&2
  exit 1
fi

# Convert ELF to Intel HEX (USim only loads HEX)
# NB: BSD mktemp on macOS only substitutes X's when at the END of the
# template — a trailing ".hex" suffix is taken literally and produces
# /tmp/mc6809-XXXXXX (verbatim), which collides on the second call.
hex=$(mktemp /tmp/mc6809.XXXXXXXX)
trap "rm -f $hex" EXIT

$OBJCOPY -O ihex "$elf" "$hex" 2>/dev/null
if [ $? -ne 0 ]; then
  echo "run-mc6809: failed to convert $elf to hex" >&2
  exit 1
fi

# Append a reset vector at 0xFFFE pointing to _start.
# picolibc's linker script doesn't emit MC6809 vectors, so the hex file
# has nothing at 0xFFFE. USim reads [0xFFFE:0xFFFF] as the initial PC.
start_addr=$($NM "$elf" 2>/dev/null | awk '$3=="_start" {print $1; exit}')
if [ -n "$start_addr" ]; then
  # Build a 2-byte record at 0xFFFE containing _start (big-endian on 6809)
  hi=$(printf '%s' "$start_addr" | sed 's/.*\(....\)$/\1/' | cut -c1-2)
  lo=$(printf '%s' "$start_addr" | sed 's/.*\(....\)$/\1/' | cut -c3-4)
  # Intel HEX record: :LL AAAA TT DD CC  (len=02, addr=FFFE, type=00, data, checksum)
  # checksum = two's complement of sum of all bytes
  sum=$((0x02 + 0xFF + 0xFE + 0x00 + 0x$hi + 0x$lo))
  cksum=$(printf '%02X' $(( (256 - (sum & 0xFF)) & 0xFF )))
  # Insert before the EOF record (the last ":00000001FF" line)
  awk -v rec=":02FFFE00$hi$lo$cksum" '
    /^:00000001FF/ { print rec; print; next }
    { print }
  ' "$hex" > "$hex.tmp" && mv "$hex.tmp" "$hex"
fi

# Run simulator
echo "$stdin" | $USIM --timeout="${USIM_TIMEOUT:-500000000}" "$hex"
