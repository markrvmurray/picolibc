#!/usr/bin/env python3
"""
Run picolibc test binaries via meson, honouring meson's exit-code
semantics (rc=77 SKIP, rc=99 ERROR, should_fail inversion, etc).

Replaces an earlier hand-rolled bash tally that misclassified rc=77
as FAIL and ignored should_fail. Classification is delegated to
`meson test` itself — the source of truth — and we only filter out
tests whose binaries don't currently build, so compile gaps don't
take out the whole run.

Outputs:
  /tmp/picolibc-results.txt   — one line per test, plus tally
  /tmp/picolibc-failures.log  — stdout+stderr of every non-OK test

Environment overrides:
  PICOLIBC_BUILDDIR   build directory (default: <repo>/builddir-mc6809)
  USIM09BATCH         USim binary
  LLVM_OBJCOPY        llvm-objcopy
  LLVM_NM             llvm-nm
"""

import json
import os
import subprocess
import sys
from collections import Counter

REPO     = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
BUILDDIR = os.environ.get("PICOLIBC_BUILDDIR", f"{REPO}/builddir-mc6809")

OUT     = "/tmp/picolibc-results.txt"
FAILLOG = "/tmp/picolibc-failures.log"
LOGBASE = "mc6809-tally"


def existing_binary_tests():
    """Tests from intro-tests.json whose cmd[0] is an existing executable.

    Skips picolibc:headers (cdef checks, not runtime tests)."""
    with open(f"{BUILDDIR}/meson-info/intro-tests.json") as f:
        tests = json.load(f)
    keep = []
    for t in tests:
        if "picolibc:headers" in t["suite"]:
            continue
        cmd0 = t["cmd"][0] if t["cmd"] else None
        if cmd0 and os.path.isfile(cmd0) and os.access(cmd0, os.X_OK):
            keep.append(t)
    return keep


def run_meson_test(test_names):
    """Invoke meson test for the named tests, return path to JSON log."""
    env = os.environ.copy()
    cmd = [
        "meson", "test",
        "-C", BUILDDIR,
        "--no-rebuild",
        "--num-processes", "1",
        "--logbase", LOGBASE,
        "--print-errorlogs",
        "-q",
        "--",
    ] + test_names
    print(f"running {len(test_names)} tests via meson…", flush=True)
    subprocess.run(cmd, env=env, stdout=subprocess.DEVNULL,
                   stderr=subprocess.DEVNULL)
    return f"{BUILDDIR}/meson-logs/{LOGBASE}.json"


def parse_meson_log(path):
    """Yield (name, result, returncode, stdout, stderr, duration) per test."""
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            r = json.loads(line)
            yield (
                r.get("name", "?"),
                r.get("result", "?"),
                r.get("returncode", -1),
                r.get("stdout", ""),
                r.get("stderr", ""),
                r.get("duration", 0.0),
            )


def main():
    tests = existing_binary_tests()
    if not tests:
        print("no buildable test binaries found", file=sys.stderr)
        return 1

    names = [t["name"] for t in tests]
    log = run_meson_test(names)
    if not os.path.exists(log):
        print(f"meson did not produce {log}", file=sys.stderr)
        return 1

    results = list(parse_meson_log(log))
    counts = Counter(r[1] for r in results)

    with open(OUT, "w") as ftally, open(FAILLOG, "w") as flog:
        for name, result, rc, out, err, dur in sorted(results):
            ftally.write(f"{result:14s} rc={rc:<4d} {dur:6.2f}s  {name}\n")
            if result not in ("OK", "EXPECTEDFAIL", "SKIP"):
                flog.write("=" * 70 + "\n")
                flog.write(f"{result}: {name}  (rc={rc}, {dur:.2f}s)\n")
                flog.write("-" * 70 + "\n")
                if out:
                    flog.write("--- stdout ---\n" + out.rstrip() + "\n")
                if err:
                    flog.write("--- stderr ---\n" + err.rstrip() + "\n")
                flog.write("\n")
        ftally.write("-" * 50 + "\n")
        for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL", "UNEXPECTEDPASS",
                  "ERROR", "TIMEOUT"):
            if counts.get(k):
                ftally.write(f"{k:14s} {counts[k]}\n")
        ftally.write(f"TOTAL          {sum(counts.values())}\n")

    parts = [f"{k}={counts[k]}"
             for k in ("OK", "EXPECTEDFAIL", "SKIP", "FAIL",
                       "UNEXPECTEDPASS", "ERROR", "TIMEOUT")
             if counts.get(k)]
    print("  ".join(parts) + f"  TOTAL={sum(counts.values())}")
    print(f"per-test: {OUT}")
    print(f"failure logs: {FAILLOG}")
    return 0


if __name__ == "__main__":
    sys.exit(main())