#!/bin/sh
#
# run-mc6809 — picolibc test runner for MC6809 (usim09batch)
#
# Usage: run-mc6809 <elf> [--stdin "string"] [--args "args"]
#
# Since usim09batch's load_elf landed (commit 1d0610d for the PT_LOAD
# walk + reset-vector $FFFE ← _start fallback; commit 2734c8d for the
# Bug #331 SWI3 $FFF2 ← __swi3_trap fallback), USim reads ELF files
# directly and wires both vectors from the ELF symbol table. No
# host-side hex conversion or vector inject is needed.
#

USIM="${USIM09BATCH:-usim09batch}"

elf="$1"
shift

stdin=""
args=""
done=0
while [ $# -gt 0 -a $done -eq 0 ]; do
  case "$1" in
    --stdin)
      stdin="$2"
      shift 2
      ;;
    --args)
      args="$2"
      shift 2
      ;;
    *)
      done=1
      ;;
  esac
done

if [ -z "$elf" ]; then
  echo "usage: run-mc6809 <elf> [--stdin string] [--args string]" >&2
  exit 1
fi

# USIM_CYCLES=1 opts into canonical-cycle reporting; usim09batch then
# emits 'cycles=<N>' on stderr which the tally harness picks up.
cycles_flag=""
if [ "${USIM_CYCLES:-0}" = "1" ]; then
  cycles_flag="--cycles"
fi
# Default cap 2B instructions (4x headroom over the slow string tests
# at ~500M). usim returns rc 124 on cap-hit (GNU timeout convention);
# we relay it unchanged so the python harness can reclassify
# FAIL -> TIMEOUT.
echo "$stdin" | $USIM --timeout="${USIM_TIMEOUT:-2000000000}" $cycles_flag "$elf"
